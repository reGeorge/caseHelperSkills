      "value": "autotest_用户模板",
      "note": ""
    },
    {
      "name": "userPackageUuid",
      "value": "DEFAULT_PACKAGE_FREE",
      "note": ""
    },
    {
      "name": "userTemplateUuid",
      "value": "take_usegroup_default_value",
      "note": ""
    }
  ],
  "outputs": [
    {
      "name": "userTemplateUUID2add",
      "expression": "$.data[?(@.userTemplateName =~ /.*autotest.*/)].userTemplateUuid[0]"
    }
  ]
