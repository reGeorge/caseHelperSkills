{
  "alias": "【公共】新增LDAP认证源",
  "case_id": 62166,
  "name": "【公共】新增LDAP认证源",
  "description": "功能说明：该公共步骤主要用于 '【公共】新增LDAP认证源' 操作。\n依赖入参：ldapIdentifySourceName2test, userPackageUuid, userTemplateUuid\n抛出变量：ldapSourceId2test",
  "inputs": [
    {
      "name": "ldapIdentifySourceName2test",
      "value": "autotest_ldap",
      "note": ""
    },
    {
      "name": "userPackageUuid",
      "value": "DEFAULT_PACKAGE_FREE",
      "note": ""
    },
    {
      "name": "userTemplateUuid",
      "value": "take_usegroup_default_value",
      "note": ""
    }
  ],
  "outputs": [
    {
      "name": "ldapSourceId2test",
      "expression": "$.data.ldap[?(@.identitySourceName=~ /.*autotest_ldap.*/)].id[0]"
    }
  ]
}