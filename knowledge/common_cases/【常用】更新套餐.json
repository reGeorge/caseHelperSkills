{
  "alias": "【常用】更新套餐",
  "case_id": 65867,
  "name": "【常用】更新套餐",
  "description": "功能说明：该公共步骤主要用于 '【常用】更新套餐' 操作。\n依赖入参：userTemplateName2test, packageName2test, usermabMaxNumber, concurrent, enableRepeat, enableKickUsermab, enableUsermabNumberLimit\n抛出变量：userTemplateUuid, userPackageUuid",
  "inputs": [
    {
      "name": "userTemplateName2test",
      "value": "autotest_计费备份用户模板",
      "note": "",
      "note_source": "empty"
    },
    {
      "name": "packageName2test",
      "value": "autotest_计费备份套餐",
      "note": "",
      "note_source": "empty"
    },
    {
      "name": "usermabMaxNumber",
      "value": "10",
      "note": "",
      "note_source": "empty"
    },
    {
      "name": "concurrent",
      "value": "10",
      "note": "",
      "note_source": "empty"
    },
    {
      "name": "enableRepeat",
      "value": "true",
      "note": "",
      "note_source": "empty"
    },
    {
      "name": "enableKickUsermab",
      "value": "false",
      "note": "",
      "note_source": "empty"
    },
    {
      "name": "enableUsermabNumberLimit",
      "value": "true",
      "note": "",
      "note_source": "empty"
    }
  ],
  "outputs": [
    {
      "name": "userTemplateUuid",
      "expression": "$.data[?(@.userTemplateName =~ /.*autotest_计费备份用户模板.*/)].userTemplateUuid[0]"
    },
    {
      "name": "userPackageUuid",
      "expression": "$.data[?(@.userPackageName =~ /.*autotest_计费备份套餐.*/)].userPackageUuid[0]"
    }
  ],
  "sync_metadata": {
    "note_initialized_count": 0
  }
