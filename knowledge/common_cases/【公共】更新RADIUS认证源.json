    },
    {
      "name": "userPackageUuid",
      "value": "DEFAULT_PACKAGE_FREE",
      "note": "资源UUID",
      "note_source": "inferred"
    },
    {
      "name": "userTemplateUuid",
      "value": "take_usegroup_default_value",
      "note": "资源UUID",
      "note_source": "inferred"
    }
  ],
  "outputs": [
    {
      "name": "radiusSourceId2update",
      "expression": "$.data.radius[?(@.identitySourceName=~ /.*autotest_radius.*/)].id[0]"
    },
    {
      "name": "data",
      "expression": "$.data"
    }
  ],
  "sync_metadata": {
    "note_initialized_count": 2
  }
}