{
  "alias": "【公共】新增RADIUS认证源",
  "case_id": 62481,
  "name": "【公共】新增RADIUS认证源",
  "description": "功能说明：该公共步骤主要用于 '【公共】新增RADIUS认证源' 操作。\n依赖入参：adIdentifySourceName2test, userPackageUuid, userTemplateUuid\n抛出变量：radiusSourceId2test",
  "inputs": [
    {
      "name": "adIdentifySourceName2test",
      "value": "autotest_radius",
      "note": ""
    },
    {
      "name": "userPackageUuid",
      "value": "DEFAULT_PACKAGE_FREE",
      "note": ""
    },
    {
      "name": "userTemplateUuid",
      "value": "take_usegroup_default_value",
      "note": ""
    }
  ],
  "outputs": [
    {
      "name": "radiusSourceId2test",
      "expression": "$.data.radius[?(@.identitySourceName=~ /.*autotest.*/)].id[0]"
    }
  ]
}