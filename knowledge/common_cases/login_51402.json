{
  "alias": "login_51402",
  "case_id": 51402,
  "name": "【公共】【鉴权】自助端登录（指定账号/密码：userId2test+password2test）",
  "description": "功能说明：该公共步骤主要用于 '【公共】【鉴权】自助端登录（指定账号/密码：userId2test+password2test）' 操作。\n依赖入参：userId2test, password2test\n抛出变量：flowkey, ssoHost1, ssoHost",
  "inputs": [
    {
      "name": "userId2test",
      "value": "binweinet",
      "note": ""
    },
    {
      "name": "password2test",
      "value": "12345aA!",
      "note": ""
    }
  ],
  "outputs": [
    {
      "name": "flowkey",
      "expression": "id=\"login-page-flowkey\"[^>]*>([^<]+)<"
    },
    {
      "name": "ssoHost1",
      "expression": "(https?://[a-zA-Z0-9.-]+(?::\\d+)?)"
    },
    {
      "name": "ssoHost",
      "expression": "https?://[a-zA-Z0-9.-]+(?:/[a-zA-Z0-9._~!$&'()*+,;=:@%-]+)*"
    }
  ]
}